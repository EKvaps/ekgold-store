import tkinter as tk
from tkinter import messagebox
import json
import os
import subprocess

# ---------------- CONFIG ----------------
RUTA_REPO = r"C:\Users\allsp\OneDrive\Desktop\ekvaps-store"
ARCHIVO_JSON = os.path.join(RUTA_REPO, "inventario.json")

# ---------------- FUNCIONES JSON ----------------

def cargar_inventario():
    if os.path.exists(ARCHIVO_JSON):
        with open(ARCHIVO_JSON, "r", encoding="utf-8") as f:
            return json.load(f)
    return []

def guardar_inventario():
    with open(ARCHIVO_JSON, "w", encoding="utf-8") as f:
        json.dump(productos, f, indent=4, ensure_ascii=False)

# ---------------- FUNCIONES GIT ----------------

def git_push():
    try:
        subprocess.run(["git", "add", "."], cwd=RUTA_REPO, check=True)
        subprocess.run(["git", "commit", "-m", "Actualización inventario"], cwd=RUTA_REPO, check=True)
        subprocess.run(["git", "push"], cwd=RUTA_REPO, check=True)
        messagebox.showinfo("GitHub", "Página actualizada 😎")
    except subprocess.CalledProcessError:
        messagebox.showerror("GitHub", "Git falló o no hubo cambios")

def refrescar_pagina():
    guardar_inventario()
    git_push()

# ---------------- FUNCIONES INVENTARIO ----------------

def actualizar_lista():
    lista.delete(0, tk.END)
    for p in productos:
        lista.insert(tk.END, f"{p['nombre']} | Stock: {p['stock']}")

def agregar_producto():
    nombre = entry_nombre.get().strip()
    stock = entry_stock.get().strip()

    if not nombre or not stock.isdigit():
        messagebox.showerror("Error", "Datos inválidos")
        return

    productos.append({
        "nombre": nombre,
        "stock": int(stock)
    })

    guardar_inventario()
    actualizar_lista()

    entry_nombre.delete(0, tk.END)
    entry_stock.delete(0, tk.END)

def eliminar_producto():
    seleccion = lista.curselection()
    if not seleccion:
        return

    index = seleccion[0]
    productos.pop(index)

    guardar_inventario()
    actualizar_lista()

# ---------------- UI ----------------

root = tk.Tk()
root.title("Inventario EKvaps")
root.geometry("600x500")
root.configure(bg="black")

titulo = tk.Label(root, text="Inventario EKvaps",
                  font=("Arial", 28, "bold"),
                  fg="gold", bg="black")
titulo.pack(pady=20)

frame = tk.Frame(root, bg="black")
frame.pack(pady=10)

tk.Label(frame, text="Nombre", fg="gold", bg="black").grid(row=0, column=0, padx=10)
tk.Label(frame, text="Stock", fg="gold", bg="black").grid(row=0, column=1, padx=10)

entry_nombre = tk.Entry(frame, font=("Arial", 14), bg="gold", fg="black", justify="center")
entry_nombre.grid(row=1, column=0, padx=10, pady=5)

entry_stock = tk.Entry(frame, font=("Arial", 14), bg="gold", fg="black", justify="center")
entry_stock.grid(row=1, column=1, padx=10, pady=5)

btn_agregar = tk.Button(root, text="Agregar Producto",
                        font=("Arial", 14, "bold"),
                        bg="gold", fg="black",
                        command=agregar_producto)
btn_agregar.pack(pady=10)

btn_eliminar = tk.Button(root, text="Eliminar Seleccionado",
                         font=("Arial", 14, "bold"),
                         bg="gold", fg="black",
                         command=eliminar_producto)
btn_eliminar.pack(pady=5)

lista = tk.Listbox(root, font=("Arial", 14),
                   bg="black", fg="gold",
                   width=50, height=10)
lista.pack(pady=20)

btn_refrescar = tk.Button(root, text="🔄 Refrescar Página",
                          font=("Arial", 16, "bold"),
                          bg="gold", fg="black",
                          command=refrescar_pagina)
btn_refrescar.pack(pady=10)

# ---------------- DATOS ----------------

productos = cargar_inventario()
actualizar_lista()

root.mainloop()
